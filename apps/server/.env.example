DATABASE_URL=postgresql://user:password@localhost:5435/solmarket_db
SERVER_REDIS_URL=redis://localhost:6380
SERVER_PORT=8080

# 32-byte base64 secret. Generate with: openssl rand -base64 32
SERVER_AUTH_SECRET=

SERVER_RESEND_API_KEY=
SERVER_WEB_ORIGIN=http://localhost:3000

# Polymarket integration
SERVER_POLYMARKET_API_KEY=
SERVER_POLYMARKET_SECRET=
SERVER_POLYMARKET_PASSPHRASE=
SERVER_POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/
SERVER_POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com

# Custodial wallet
# 32-byte base64 secret used to AES-256-GCM encrypt user keypair seeds at rest.
# Loss of this key = total loss of user funds. Never commit. Generate with:
#   openssl rand -base64 32
SERVER_KEY_ENCRYPTION_KEY=
# Public mainnet RPC rate-limits hard. Use Helius/Triton/QuickNode for prod.
SERVER_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SERVER_USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
