{
    "name": "mirror",
    "module": "index.ts",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "bun --hot index.ts",
        "start": "bun index.ts",
        "build": "bun build index.ts --outdir dist --target bun",
        "typecheck": "tsc --noEmit",
        "lint": "eslint . --max-warnings 0",
        "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
        "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
    },
    "devDependencies": {
        "@solmarket/eslint-config": "*",
        "@solmarket/typescript-config": "*",
        "@solmarket/polymarket-contracts": "*",
        "@types/bun": "latest",
        "@types/ws": "^8.18.1",
        "eslint": "^8.57.0",
        "prettier": "^3.2.5"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "dependencies": {
        "chalk": "^5.6.2",
        "ioredis": "^5.10.1",
        "ws": "^8.20.0",
        "zod": "^4.3.6"
    }
}
