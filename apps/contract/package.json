{
  "name": "contract",
  "license": "ISC",
  "scripts": {
    "lint:fix": "prettier \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier \"*/**/*{.js,.ts}\" --check",
    "sync": "node -e \"const idl=require('./target/idl/contract.json');const fs=require('fs');fs.writeFileSync('../../packages/contract/src/idl.ts','export const IDL = '+JSON.stringify(idl,null,2)+' as const;\\n')\" && cp target/types/contract.ts ../../packages/contract/src/contract.ts",
    "build:sync": "anchor build && bun sync",
    "mint": "npx ts-node --skip-project --compiler-options '{\"module\":\"commonjs\",\"target\":\"es2020\",\"esModuleInterop\":true}' scripts/mint-test-tokens.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1"
  },
  "devDependencies": {
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "@types/node": "^25.6.0",
    "chai": "^4.3.4",
    "mocha": "^9.0.3",
    "prettier": "^2.6.2",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.7.3"
  }
}
