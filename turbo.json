{
  "$schema": "https://turborepo.dev/schema.json",
  "globalEnv": ["SERVER_POLYMARKET_GAMMA_URL", "AUTO_LISTER_INTERVAL_MS"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "db:migrate:dev": {
      "cache": false,
      "persistent": true
    },
    "db:migrate:deploy": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:seed": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "generate": {
      "dependsOn": ["^generate"],
      "cache": false
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "lint": {}
  }
}
