model Market {
  id          String @id @default(cuid())
  name        String
  description String

  solanaMarketPda String? @unique

  polyMarketId String     @unique
  polymarket   PolyMarket @relation(fields: [polyMarketId], references: [id])

  status         MarketStatus @default(OPEN)
  winningOutcome Outcome?
  /// STANDARD = regular long-form market (default).
  /// FAST_MOVING = short-window auto-rolling market (Polymarket BTC/ETH/SOL
  /// Up-or-Down ladders). Surfaced in a dedicated admin tab and resolved
  /// on-chain immediately by MarketStatusPoller — the hedger's 48h dispute
  /// window doesn't apply to these.
  kind           MarketKind   @default(STANDARD)
  /// For FAST_MOVING markets, the stable identifier of the rolling
  /// series they belong to — e.g. "bitcoin-updown-5m",
  /// "dogecoin-updown-15m". Derived from the Polymarket slug. Used by
  /// FastMarketSubscription to auto-approve every new market that lands
  /// in a subscribed series. Null for STANDARD markets and for
  /// FAST_MOVING ones whose slug doesn't match the recognised pattern.
  fastSeriesKey  String?
  /// Why the market is currently non-OPEN. Set by the hedger when it
  /// detects external state changes on Polymarket — currently only
  /// "UMA_DISPUTE" (Polymarket closed the market but the winning outcome
  /// is not yet determinable because of an open UMA dispute). Null when
  /// status is OPEN, or when RESOLVED with a known winner.
  pausedReason   String?

  createdAt  DateTime  @default(now())
  endAt      DateTime
  resolvedAt DateTime?

  quotes            Quote[]
  fills             Fill[]
  claims            Claim[]
  exposure          Exposure?
  listing           Listing?
  bookmarks         Bookmark[]
  platformInventory PlatformInventory[]

  @@unique([id, polyMarketId])
  @@unique([id, solanaMarketPda])
}

model Bookmark {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketId  String
  market    Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, marketId])
  @@index([userId, createdAt])
  @@index([marketId])
}

model Listing {
  marketId        String        @id
  market          Market        @relation(fields: [marketId], references: [id])
  status          ListingStatus @default(PENDING)
  volume24hUsd    Float?
  liquidityUsd    Float?
  lastSyncedAt    DateTime?
  discoveredAt    DateTime      @default(now())
  approvedAt      DateTime?
  approvedBy      String?
  rejectedAt      DateTime?
  rejectionReason String?
}

model PolyMarket {
  id         String   @id
  slug       String?
  eventId    String?
  eventSlug  String?
  yesTokenId String
  noTokenId  String
  tickSize   String
  negRisk    Boolean
  imageUrl   String?
  tags       String[] @default([])

  market Market?

  @@index([eventId])
  @@index([tags], type: Gin)
}

model Comment {
  id          String   @id @default(cuid())
  eventId     String
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  body        String   @db.VarChar(2000)
  reportCount Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([eventId, createdAt])
  @@index([userId])
}

model Quote {
  nonce          String    @id
  marketId       String
  market         Market    @relation(fields: [marketId], references: [id])
  side           Side
  outcome        Outcome
  price          Int
  size           Int
  expiresAt      DateTime
  signature      String
  consumed       Boolean   @default(false)
  /** When the on-chain UsedNonce PDA was closed by the sweeper. Null until close lands. */
  nonceClosedAt  DateTime?
  createdAt      DateTime  @default(now())

  fill Fill?

  @@index([consumed, nonceClosedAt, expiresAt])
}

model Fill {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id])
  marketId String
  market   Market @relation(fields: [marketId], references: [id])

  side    Side
  outcome Outcome
  price   Int
  size    Int

  solanaTxSig String  @unique
  nonce       String? @unique
  quote       Quote?  @relation(fields: [nonce], references: [nonce])

  /**
   * If this fill consumed an existing PlatformInventory row (instead of
   * placing a fresh Polymarket order), points back to that row. Null for
   * the common case (Polymarket-fill-then-Solana-commit).
   */
  nettedFromInventoryId String?            @unique
  nettedFromInventory   PlatformInventory? @relation(fields: [nettedFromInventoryId], references: [id])

  createdAt DateTime @default(now())

  hedge Hedge?
}

/// Records a successful `claim` instruction. The on-chain claim zeroes the
/// user's winning-side shares in their UserPosition PDA and transfers
/// `shares × $1` USDC from the treasury vault to the user's ATA. The DB
/// row exists so PortfolioService can hide already-claimed positions on
/// page refresh — without it, the position keeps showing up with
/// `claimableUsd > 0` because the Fill aggregation has no way to know
/// the user already redeemed. One row per (user, market, outcome) by
/// design — the on-chain handler drains the full balance in one shot.
model Claim {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  marketId    String
  market      Market   @relation(fields: [marketId], references: [id])
  outcome     Outcome
  shares      Int
  payoutCents Int
  txSignature String   @unique
  createdAt   DateTime @default(now())

  @@unique([userId, marketId, outcome])
  @@index([userId])
}

model Hedge {
  id     String @id @default(cuid())
  fillId String @unique
  fill   Fill   @relation(fields: [fillId], references: [id])

  polymarketOrderId String?
  polymarketTokenId String?
  polymarketSide    Side?
  bullJobId         String?     @unique
  clientOrderId     String?     @unique
  requestedSize     Int?
  status            HedgeStatus @default(PENDING)
  filledSize        Int         @default(0)
  avgPrice          Int?
  attempts          Int         @default(0)
  lastError         String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?
}

model Exposure {
  marketId        String    @id
  market          Market    @relation(fields: [marketId], references: [id])
  unhedgedUsd     Int       @default(0)
  trackerEnabled  Boolean   @default(true)
  paused          Boolean   @default(false)
  lastIncrementAt DateTime?
  lastDecrementAt DateTime?
  updatedAt       DateTime  @updatedAt
}

model TreasuryBalance {
  chain     Chain
  token     String
  amount    BigInt
  updatedAt DateTime @updatedAt

  @@id([chain, token])
}

/**
 * Tracks Polymarket positions the platform holds without a corresponding
 * user Fill — typically because the Solana place_order leg permanently
 * failed *after* the Polymarket leg already filled. The orchestrator nets
 * these against opposite-direction user trades when possible; the
 * liquidator sweeps anything older than the configured stale window.
 */
model PlatformInventory {
  id                 String          @id @default(cuid())
  marketId           String
  market             Market          @relation(fields: [marketId], references: [id])
  polymarketOrderId  String          @unique
  polymarketTokenId  String
  // The position the platform now holds, awaiting netting or liquidation.
  // Side from our trade-direction POV: BUY = we own these shares (long the outcome),
  // SELL = we sold (short the outcome).
  side               Side
  outcome            Outcome
  shares             Int
  avgPriceCents      Int
  reason             InventoryReason
  // Lifecycle timestamps.
  createdAt          DateTime        @default(now())
  nettedAt           DateTime?
  /** Fill.id of the user trade that consumed this inventory (1:1 link via Fill.nettedFromInventoryId). */
  nettedFromFill     Fill?
  liquidatedAt       DateTime?
  liquidateOrderId   String?
  notes              String?

  @@index([marketId, nettedAt, liquidatedAt])
  @@index([createdAt])
}
