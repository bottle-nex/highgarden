model Market {
  id          String @id @default(cuid())
  name        String
  description String

  solanaMarketPda String? @unique

  polyMarketId String     @unique
  polymarket   PolyMarket @relation(fields: [polyMarketId], references: [id])

  status         MarketStatus @default(OPEN)
  winningOutcome Outcome?

  createdAt  DateTime  @default(now())
  endAt      DateTime
  resolvedAt DateTime?

  quotes    Quote[]
  fills     Fill[]
  exposure  Exposure?
  listing   Listing?
  bookmarks Bookmark[]

  @@unique([id, polyMarketId])
  @@unique([id, solanaMarketPda])
}

model Bookmark {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketId  String
  market    Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, marketId])
  @@index([userId, createdAt])
  @@index([marketId])
}

model Listing {
  marketId        String        @id
  market          Market        @relation(fields: [marketId], references: [id])
  status          ListingStatus @default(PENDING)
  volume24hUsd    Float?
  liquidityUsd    Float?
  lastSyncedAt    DateTime?
  discoveredAt    DateTime      @default(now())
  approvedAt      DateTime?
  approvedBy      String?
  rejectedAt      DateTime?
  rejectionReason String?
}

model PolyMarket {
  id         String   @id
  slug       String?
  eventId    String?
  eventSlug  String?
  yesTokenId String
  noTokenId  String
  tickSize   String
  negRisk    Boolean
  imageUrl   String?
  tags       String[] @default([])

  market Market?

  @@index([eventId])
  @@index([tags], type: Gin)
}

model Comment {
  id          String   @id @default(cuid())
  eventId     String
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  body        String   @db.VarChar(2000)
  reportCount Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([eventId, createdAt])
  @@index([userId])
}

model Quote {
  nonce          String    @id
  marketId       String
  market         Market    @relation(fields: [marketId], references: [id])
  side           Side
  outcome        Outcome
  price          Int
  size           Int
  expiresAt      DateTime
  signature      String
  consumed       Boolean   @default(false)
  /** When the on-chain UsedNonce PDA was closed by the sweeper. Null until close lands. */
  nonceClosedAt  DateTime?
  createdAt      DateTime  @default(now())

  fill Fill?

  @@index([consumed, nonceClosedAt, expiresAt])
}

model Fill {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id])
  marketId String
  market   Market @relation(fields: [marketId], references: [id])

  side    Side
  outcome Outcome
  price   Int
  size    Int

  solanaTxSig String  @unique
  nonce       String? @unique
  quote       Quote?  @relation(fields: [nonce], references: [nonce])

  createdAt DateTime @default(now())

  hedge Hedge?
}

model Hedge {
  id     String @id @default(cuid())
  fillId String @unique
  fill   Fill   @relation(fields: [fillId], references: [id])

  polymarketOrderId String?
  polymarketTokenId String?
  polymarketSide    Side?
  bullJobId         String?     @unique
  clientOrderId     String?     @unique
  requestedSize     Int?
  status            HedgeStatus @default(PENDING)
  filledSize        Int         @default(0)
  avgPrice          Int?
  attempts          Int         @default(0)
  lastError         String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?
}

model Exposure {
  marketId        String    @id
  market          Market    @relation(fields: [marketId], references: [id])
  unhedgedUsd     Int       @default(0)
  trackerEnabled  Boolean   @default(true)
  paused          Boolean   @default(false)
  lastIncrementAt DateTime?
  lastDecrementAt DateTime?
  updatedAt       DateTime  @updatedAt
}

model TreasuryBalance {
  chain     Chain
  token     String
  amount    BigInt
  updatedAt DateTime @updatedAt

  @@id([chain, token])
}
